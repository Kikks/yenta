# --- GitHub ---
# Personal Access Token with: repo (full), read:org, read:user
# Classic PAT works; fine-grained PAT must have: Contents R/W, Pull Requests R/W, Metadata R
GITHUB_TOKEN=ghp_xxx

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxx
# Default model. Override per-environment if you want.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Observability (Langfuse) ---
# Get these from your Langfuse project settings.
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Agent tuning (optional; sensible defaults are in pr_agent/config.py) ---
# Token budget per per-file analyze call. Hunks are split below this.
MAX_TOKENS_PER_FILE_CHUNK=6000
# Hard cap on total LLM calls per PR (safety net for monorepo PRs).
MAX_LLM_CALLS_PER_RUN=80
# Bounded concurrency in the analyze node. 1 = sequential (pre-concurrency
# behaviour). Default 4. Internally clamped to [1, 8] — values above 8 risk
# Anthropic's per-key rate limits on long monorepo PRs.
ANALYZE_CONCURRENCY=4
